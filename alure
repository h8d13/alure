# Helper to strip version from names
def strip_version(package_string):
    """Strip version from package string."""
    parts = package_string.split('-')
    for i, part in enumerate(parts):
        if part and part[0].isdigit():
            return '-'.join(parts[:i])
    return package_string

def loading_animation(duration=0.5):
    """Show a brief loading animation before returning to menu."""
    frames = ['|', '/', '—', '\\']
    end_time = time.time() + duration
    i = 0
    while time.time() < end_time:
        print(f'\r{frames[i % len(frames)]}', end='', flush=True)
        time.sleep(0.1)
        i += 1
    print('\r ', end='', flush=True)  # Clear the animation

def extract_package_name(line):
    """Extract package name from marked line (with or without • prefix)."""
    # Remove all ANSI codes
    line = Colors.strip(line)
    # Remove prefix (• or 2 spaces) - check once
    if line[:2] in ('• ', '  '):
        line = line[2:]
    # Get first field (package name with version), split on any whitespace
    pkg_full = line.split(None, 1)[0]
    # Strip version
    return strip_version(pkg_full)

def get_installed_packages():
    """Get set of installed package names."""
    result = PackageManager.list_installed()
    if not result:
        return set()

    # Use set comprehension for efficiency
    installed = set()
    for line in result.split('\n'):
        if line and '[installed]' in line:
            # Format: package-version-arch {origin} (license) [installed]
            pkg_full = line.split(None, 1)[0]  # Get first field, split on any whitespace
            pkg_name = strip_version(pkg_full)
            installed.add(pkg_name)
    return installed

def update_cache():
    """Update package cache."""
    cache_file = CACHE_DIR / 'packages.cache'

    if cache_file.exists():
        cache_age = time.time() - cache_file.stat().st_mtime
        if cache_age < CACHE_DURATION:
            return

    print(Colors.cyan("Updating cache..."), file=sys.stderr)
    result = PackageManager.search(pattern='', verbose=True, description=True)
    if result:
        cache_file.write_text(result)

def search_packages(query='', search_desc=False):
    """Search and browse packages."""
    update_cache()

    cache_file = CACHE_DIR / 'packages.cache'
    if not cache_file.exists():
        print(Colors.red("Cache not found"))
        return

    # Get installed packages once
    installed = get_installed_packages()

    # Pre-calculate marker strings for installed status (will be in separate column)
    installed_marker = f"{Colors.GREEN}•{Colors.NC}"
    not_installed_marker = " "

    # Build package list with proper column separation
    # Format: marker<TAB>pkg_full<TAB>description
    # This allows fzf to search and prioritize columns independently

    # Find max package name length for alignment
    MAX_PKG_WIDTH = 40  # Fixed width for alignment

    if query:
        # Sort by query match - use tuples for priority then sort
        q = query.lower()
        matches = []

        with open(cache_file) as f:
            for line in f:
                line = line.rstrip('\n')
                if not line:
                    continue

                # Parse: "package-version - description"
                parts = line.split(' - ', 1)
                pkg_full = parts[0]
                description = parts[1] if len(parts) > 1 else ''

                pkg_name = strip_version(pkg_full.split()[0])
                pkg_name_lower = pkg_name.lower()
                line_lower = line.lower()

                # Determine priority
                if pkg_name_lower == q:
                    priority = 0
                elif pkg_name_lower.startswith(q):
                    priority = 1
                elif q in pkg_name_lower:
                    priority = 2
                elif q in line_lower:
                    priority = 3
                else:
                    continue  # Skip non-matches to save memory

                is_installed = pkg_name in installed
                marker = installed_marker if is_installed else not_installed_marker
                # Pad package name for alignment
                pkg_padded = pkg_full.ljust(MAX_PKG_WIDTH)
                # Format: marker pkg_padded<TAB>description (space after marker, tab before desc)
                matches.append((priority, f"{marker} {pkg_padded}\t{description}\n"))

        # Sort by priority and build output
        matches.sort(key=lambda x: x[0])
        input_data = ''.join(match[1] for match in matches)
    else:
        # No query - build with column separation for proper fzf prioritization
        lines = []
        with open(cache_file) as f:
            for line in f:
                line = line.rstrip('\n')
                if not line:
                    continue

                # Parse: "package-version - description"
                parts = line.split(' - ', 1)
                pkg_full = parts[0]
                description = parts[1] if len(parts) > 1 else ''

                pkg_name = strip_version(pkg_full.split()[0])
                is_installed = pkg_name in installed
                marker = installed_marker if is_installed else not_installed_marker
                # Pad package name for alignment
                pkg_padded = pkg_full.ljust(MAX_PKG_WIDTH)
                # Format: marker pkg_padded<TAB>description (space after marker, tab before desc)
                lines.append(f"{marker} {pkg_padded}\t{description}\n")

        input_data = ''.join(lines)

    # Check if we have data
    if not input_data.strip():
        print(Colors.red("Error: No packages to display"))
        return

    # Use FzfInterface
    try:
        fzf = FzfInterface(SCRIPT_DIR)
    except FileNotFoundError as e:
        print(Colors.red(str(e)))
        return

    # For interactive search, remove the extra options that break filtering
    result = fzf.run(
        input_data=input_data,
        prompt='Search > ',
        header='•:installed  ⏎:install/remove',
        query=query,
        extra_options=['--tiebreak=index'] if query else [],
        border_label='[ Packages ]',
        preview_label='[ Info ]',
        multi=False,
        search_description=search_desc
    )

    if result:
        # Check if installed
        is_installed = '•' in result

        # Get package name
        pkg_name = extract_package_name(result)

        if is_installed:
            print(Colors.yellow(f"Removing: {pkg_name}"))
            success = PackageManager.remove(pkg_name)
            if success:
                print(Colors.green(f"Successfully removed: {pkg_name}"))
        else:
            print(Colors.green(f"Installing: {pkg_name}"))
            success = PackageManager.install(pkg_name)
            if success:
                print(Colors.green(f"Successfully installed: {pkg_name}"))

        # Brief loading animation before returning to menu
        loading_animation(0.5)
        # Return to menu (recursive call)
        search_packages(query)

def world_packages():
    """Browse world packages (explicitly installed)."""
    world_file = Path('/etc/apk/world')

    if not world_file.exists():
        print(Colors.red("World file not found"))
        return

    # Read world file - filter empty/comment lines immediately
    world_pkgs = [
        line.strip() for line in world_file.read_text().split('\n')
        if line.strip() and not line.startswith('#')
    ]

    # Get full package info for each (batch processing would be better but apk doesn't support it)
    pkg_lines = []
    for pkg in world_pkgs:
        result = PackageManager.list_installed(pkg)
        if result:
            stripped = result.strip()
            if stripped:
                pkg_lines.append(stripped)

    if not pkg_lines:
        print(Colors.yellow("No packages in world"))
        return

    # Use FzfInterface
    try:
        fzf = FzfInterface(SCRIPT_DIR)
    except FileNotFoundError as e:
        print(Colors.red(str(e)))
        return

    result = fzf.run(
        input_data='\n'.join(pkg_lines),
        prompt='World > ',
        header='Explicit packages  ⏎:remove',
        border_label='[ Packages ]',
        preview_label='[ Info ]',
        multi=False
    )

    if result:
        pkg_name = extract_package_name(result)
        print(Colors.yellow(f"Removing from world: {pkg_name}"))
        success = PackageManager.remove(pkg_name)
        if success:
            print(Colors.green(f"Successfully removed: {pkg_name}"))

        # Brief loading animation before returning to menu
        loading_animation(0.5)
        # Return to menu
        world_packages()

