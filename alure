{Colors.yellow("Note:")}
    World file (/etc/apk/world) contains packages you explicitly installed.
    Dependencies are tracked separately by apk. In the "installed" tab.
""")

def main():
    # Check required commands efficiently (avoid spawning 'which' subprocess)
    import shutil
    for cmd in ['apk', 'fzf', 'doas']:
        if not shutil.which(cmd):
            print(Colors.red(f"'{cmd}' not found"))
            sys.exit(1)

    # Show help if no arguments
    if len(sys.argv) < 2:
        show_help()
        sys.exit(0)

    command = sys.argv[1]

    # Define supported flags per command
    command_flags = {
        'all': ['-d'],
        'history': ['-l', '-f']
    }

    # Check for -d flag for 'all' command and remove it from queue
    search_desc = False
    if command == 'all' and '-d' in sys.argv:
        search_desc = True
        sys.argv.remove('-d')

    # Exit on unsupported flags (skip validation for history and fp commands as they handle their own flags)
    if command not in ['history', 'fp']:
        supported_flags = command_flags.get(command, [])
        unsupported_flags = [arg for arg in sys.argv[1:] if arg.startswith('-') and arg not in supported_flags]
        if unsupported_flags:
            print(Colors.red(f"Error: Unsupported flag(s): {' '.join(unsupported_flags)}"))
            sys.exit(1)

    if command == 'search':
        if len(sys.argv) < 3:
            print(Colors.red("Error: search query required"))
            print("Usage: alure search <query>")
            sys.exit(1)
        # search always searches both name and description with priority sorting
        search_packages(sys.argv[2], search_desc=True)
    elif command == 'all':
        # all uses -d flag to control description searching
        search_packages('', search_desc)
    elif command == 'installed':
        installed_packages()
    elif command == 'world':
        world_packages()
    elif command == 'pattern':
        if len(sys.argv) < 3:
            print(Colors.red("Pattern required"))
            sys.exit(1)
        search_pattern(sys.argv[2])
    elif command == 'up':
        success = PackageManager.update_and_upgrade()
        if success:
            print(Colors.green("System updated and upgraded successfully"))
        sys.exit(0 if success else 1)
    elif command == 'clean':
        success = PackageManager.clean()
        if success:
            print(Colors.green("APK cache cleaned successfully"))
        sys.exit(0 if success else 1)
    elif command == 'history':
        history_script = SCRIPT_DIR / 'history.sh'
        if not history_script.exists():
            print(Colors.red(f"History script not found: {history_script}"))
            sys.exit(1)
        try:
            result = subprocess.run([str(history_script)] + sys.argv[2:])
            sys.exit(result.returncode)
        except subprocess.SubprocessError as e:
            print(Colors.red(f"Error running history: {e}"), file=sys.stderr)
            sys.exit(1)
    elif command == 'update-cache':
        update_cache()
    elif command == 'fp':
        if len(sys.argv) < 3:
            print(Colors.red("Error: fp subcommand required"))
            print("Usage: alure fp <setup|search|run|clean|<flatpak-cmd>> [args]")
            sys.exit(1)

        subcmd = sys.argv[2]

        # Define supported flags per fp subcommand
        fp_command_flags = {
            'setup': [],
            'search': [],
            'run': ['-b'],
            'clean': []
        }

        # Validate flags for known subcommands (skip validation for passthrough commands)
        if subcmd in fp_command_flags:
            supported_flags = fp_command_flags[subcmd]
            unsupported_flags = [arg for arg in sys.argv[3:] if arg.startswith('-') and arg not in supported_flags]
            if unsupported_flags:
                print(Colors.red(f"Error: Unsupported flag(s) for 'fp {subcmd}': {' '.join(unsupported_flags)}"))
                sys.exit(1)

        if subcmd == 'setup':
            success = FlatpakManager.setup()
            if success:
                print(Colors.green("Flatpak setup completed successfully"))
            sys.exit(0 if success else 1)
        elif subcmd == 'search':
            search_script = SCRIPT_DIR / 'fp-search.sh'
            if not search_script.exists():
                print(Colors.red(f"Search script not found: {search_script}"))
                sys.exit(1)
            # pass search term if provided
            search_term = sys.argv[3] if len(sys.argv) > 3 else ''
            result = subprocess.run([str(search_script), search_term])
            sys.exit(result.returncode)
        elif subcmd == 'run':
            # Parse flags and app name
            background = False
            app_name = None

            for arg in sys.argv[3:]:
                if arg == '-b':
                    background = True
                elif not app_name:
                    app_name = arg

            if not app_name:
                print(Colors.red("Error: app name required"))
                print("Usage: alure fp run [-b] <appname>")
                sys.exit(1)

            success = FlatpakManager.run(app_name, background=background)
            sys.exit(0 if success else 1)
        elif subcmd == 'clean':
            print(Colors.cyan("Removing unused Flatpak runtimes..."))
            success = FlatpakManager.clean()
            if success:
                print(Colors.green("Flatpak cleanup completed successfully"))
            sys.exit(0 if success else 1)
        else:
            # Pass through to flatpak command
            returncode = FlatpakManager.command(sys.argv[2:])
            sys.exit(returncode)
    elif command in ['help', 'h']:
        show_help()
    elif command in ['version', 'v']:
        print(f'{V_STRING}')
        sys.exit(0)
    else:
        print(Colors.red(f"Unknown: {command}"))
        show_help()
        sys.exit(1)

if __name__ == '__main__':
    main()

