def search_pattern(pattern):
    """Search by pattern."""
    result = PackageManager.search(pattern)
    if not result or not result.strip():
        print(Colors.yellow("No packages found"))
        return

    # Use FzfInterface
    try:
        fzf = FzfInterface(SCRIPT_DIR)
    except FileNotFoundError as e:
        print(Colors.red(str(e)))
        return

    fzf_result = fzf.run(
        input_data=result,
        prompt='Pattern > ',
        header='⏎:install',
        border_label='[ Packages ]',
        preview_label='[ Info ]',
        multi=False
    )

    if fzf_result:
        pkg_name = extract_package_name(fzf_result)
        print(Colors.green(f"Installing: {pkg_name}"))
        success = PackageManager.install(pkg_name)
        if success:
            print(Colors.green(f"Successfully installed: {pkg_name}"))

        # Brief loading animation before returning to menu
        loading_animation(0.5)
        # Return to menu
        search_pattern(pattern)

def show_deps(package):
    """Show dependency graph."""
    pkg_name = strip_version(package)
    print(Colors.blue(f"Dependencies: {pkg_name}\n"))
    PackageManager.show_deps(pkg_name)

