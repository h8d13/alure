## Used for help
V_STRING="0.1.2"

# Colors
class Colors:
    RED = '\033[0;31m'
    GREEN = '\033[0;32m'
    BLUE = '\033[0;34m'
    YELLOW = '\033[1;33m'
    CYAN = '\033[0;36m'
    NC = '\033[0m'

    # Pre-compile regex for performance
    _ansi_pattern = re.compile(r'\x1b\[[0-9;]*m')

    @classmethod
    def strip(cls, text: str) -> str:
        """Remove all ANSI color codes from text."""
        return cls._ansi_pattern.sub('', text)

    @classmethod
    def red(cls, text: str) -> str:
        """Return text in red."""
        return f"{cls.RED}{text}{cls.NC}"

    @classmethod
    def green(cls, text: str) -> str:
        """Return text in green."""
        return f"{cls.GREEN}{text}{cls.NC}"

    @classmethod
    def blue(cls, text: str) -> str:
        """Return text in blue."""
        return f"{cls.BLUE}{text}{cls.NC}"

    @classmethod
    def yellow(cls, text: str) -> str:
        """Return text in yellow."""
        return f"{cls.YELLOW}{text}{cls.NC}"

    @classmethod
    def cyan(cls, text: str) -> str:
        """Return text in cyan."""
        return f"{cls.CYAN}{text}{cls.NC}"

# Configuration
