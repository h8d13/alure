class PackageManager:
    """Handles all APK package manager operations."""

    @staticmethod
    def search(pattern: str = '', verbose: bool = False, description: bool = False) -> Optional[str]:
        """Search for packages."""
        try:
            cmd = ['apk', 'search']
            if verbose:
                cmd.append('-v')
            if description:
                cmd.append('-d')
            if pattern:
                cmd.append(pattern)
            else:
                cmd.append('')

            result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
            return result.stdout if result.returncode == 0 else None
        except (subprocess.TimeoutExpired, subprocess.SubprocessError) as e:
            print(Colors.red(f"Error searching packages: {e}"), file=sys.stderr)
            return None

    @staticmethod
    def list_installed(package: str = '') -> Optional[str]:
        """List installed packages."""
        try:
            cmd = ['apk', 'list', '-I']
            if package:
                cmd.append(package)
            result = subprocess.run(cmd, capture_output=True, text=True)
            return result.stdout if result.returncode == 0 else None
        except subprocess.SubprocessError as e:
            print(Colors.red(f"Error listing packages: {e}"), file=sys.stderr)
            return None

    @staticmethod
    def install(package: str) -> bool:
        """Install a package."""
        try:
            result = subprocess.run(['doas', 'apk', 'add', package])
            return result.returncode == 0
        except KeyboardInterrupt:
            print(Colors.yellow("\nInstallation cancelled"))
            return False
        except subprocess.SubprocessError as e:
            print(Colors.red(f"Error installing package: {e}"), file=sys.stderr)
            return False

    @staticmethod
    def remove(package: str) -> bool:
        """Remove a package."""
        try:
            result = subprocess.run(['doas', 'apk', 'del', package])
            return result.returncode == 0
        except KeyboardInterrupt:
            print(Colors.yellow("\nRemoval cancelled"))
            return False
        except subprocess.SubprocessError as e:
            print(Colors.red(f"Error removing package: {e}"), file=sys.stderr)
            return False

    @staticmethod
    def upgrade(package: str = '') -> bool:
        """Upgrade a package or all packages."""
        try:
            cmd = ['doas', 'apk', 'upgrade']
            if package:
                cmd.append(package)
            result = subprocess.run(cmd)
            return result.returncode == 0
        except KeyboardInterrupt:
            print(Colors.yellow("\nUpgrade cancelled"))
            return False
        except subprocess.SubprocessError as e:
            print(Colors.red(f"Error upgrading package: {e}"), file=sys.stderr)
            return False

    @staticmethod
    def update_and_upgrade() -> bool:
        """Update package index and upgrade all packages."""
        try:
            # First update the package index
            print(Colors.cyan("Updating package index..."))
            update_result = subprocess.run(['doas', 'apk', 'update'])
            if update_result.returncode != 0:
                print(Colors.red("Failed to update package index"))
                return False

            # Then upgrade all packages with --available flag
            print(Colors.cyan("Upgrading packages..."))
            upgrade_result = subprocess.run(['doas', 'apk', 'upgrade', '--available'])
            return upgrade_result.returncode == 0
        except KeyboardInterrupt:
            print(Colors.yellow("\nUpdate/upgrade cancelled"))
            return False
        except subprocess.SubprocessError as e:
            print(Colors.red(f"Error updating/upgrading: {e}"), file=sys.stderr)
            return False

    @staticmethod
    def clean() -> bool:
        """Clean APK cache."""
        try:
            result = subprocess.run(['doas', 'apk', 'cache', 'clean'])
            return result.returncode == 0
        except KeyboardInterrupt:
            print(Colors.yellow("\nClean cancelled"))
            return False
        except subprocess.SubprocessError as e:
            print(Colors.red(f"Error cleaning cache: {e}"), file=sys.stderr)
            return False

    @staticmethod
    def show_deps(package: str) -> bool:
        """Show dependency graph."""
        try:
            result = subprocess.run(['apk', 'dot', package])
            return result.returncode == 0
        except KeyboardInterrupt:
            print(Colors.yellow("\nCancelled"))
            return False
        except subprocess.SubprocessError as e:
            print(Colors.red(f"Error showing dependencies: {e}"), file=sys.stderr)
            return False


class FlatpakManager:
    """Handles all Flatpak operations."""

    @staticmethod
    def setup() -> bool:
        """Set up Flatpak with Flathub repository."""
        try:
            result = subprocess.run([
                'flatpak', 'remote-add', '--if-not-exists',
                'flathub', 'https://dl.flathub.org/repo/flathub.flatpakrepo'
            ])
            return result.returncode == 0
        except KeyboardInterrupt:
            print(Colors.yellow("\nSetup cancelled"))
            return False
        except subprocess.SubprocessError as e:
            print(Colors.red(f"Error setting up Flatpak: {e}"), file=sys.stderr)
            return False

    @staticmethod
    def search(query: str = '') -> Optional[str]:
        """Search for Flatpak applications."""
        try:
            cmd = ['flatpak', 'search']
            if query:
                cmd.append(query)
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
            return result.stdout if result.returncode == 0 else None
        except (subprocess.TimeoutExpired, subprocess.SubprocessError) as e:
            print(Colors.red(f"Error searching Flatpak apps: {e}"), file=sys.stderr)
            return None

    @staticmethod
    def list_apps() -> Optional[str]:
        """List installed Flatpak applications."""
        try:
            result = subprocess.run(
                ['flatpak', 'list', '--app', '--columns=application'],
                capture_output=True, text=True
            )
            return result.stdout if result.returncode == 0 else None
        except subprocess.SubprocessError as e:
            print(Colors.red(f"Error listing Flatpak apps: {e}"), file=sys.stderr)
            return None

    @staticmethod
    def find_app(query: str) -> Optional[str]:
        """Find installed app by partial name match."""
        try:
            result = subprocess.run(
                ['flatpak', 'list', '--app', '--columns=application'],
                capture_output=True, text=True
            )
            if result.returncode != 0:
                return None

            # Search for case-insensitive match
            query_lower = query.lower()
            for line in result.stdout.split('\n'):
                if line and query_lower in line.lower():
                    return line.strip()
            return None
        except subprocess.SubprocessError as e:
            print(Colors.red(f"Error finding Flatpak app: {e}"), file=sys.stderr)
            return None

    @staticmethod
    def run(app: str, background: bool = False) -> bool:
        """Run a Flatpak application (with fuzzy matching)."""
        try:
            # Try to find the app if not an exact app ID
            app_id = FlatpakManager.find_app(app)
            if not app_id:
                print(Colors.red(f"No app matching '{app}' found"))
                return False

            if background:
                # Run in background, detached from terminal
                subprocess.Popen(
                    ['flatpak', 'run', app_id],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                    start_new_session=True
                )
                print(Colors.green(f"Started {app_id} in background"))
                return True
            else:
                result = subprocess.run(['flatpak', 'run', app_id])
                return result.returncode == 0
        except KeyboardInterrupt:
            print(Colors.yellow("\nRun cancelled"))
            return False
        except subprocess.SubprocessError as e:
            print(Colors.red(f"Error running Flatpak app: {e}"), file=sys.stderr)
            return False

    @staticmethod
    def clean() -> bool:
        """Remove unused Flatpak runtimes and dependencies."""
        try:
            result = subprocess.run(['flatpak', 'uninstall', '--unused', '-y'])
            return result.returncode == 0
        except KeyboardInterrupt:
            print(Colors.yellow("\nClean cancelled"))
            return False
        except subprocess.SubprocessError as e:
            print(Colors.red(f"Error cleaning Flatpak: {e}"), file=sys.stderr)
            return False

    @staticmethod
    def command(args: List[str]) -> int:
        """Execute arbitrary Flatpak command with arguments."""
        try:
            result = subprocess.run(['flatpak'] + args)
            return result.returncode
        except KeyboardInterrupt:
            print(Colors.yellow("\nCommand cancelled"))
            return 130  # Standard exit code for SIGINT
        except subprocess.SubprocessError as e:
            print(Colors.red(f"Error executing Flatpak command: {e}"), file=sys.stderr)
            return 1


class FzfInterface:
    """Handles all fzf interactions with consistent configuration."""

    def __init__(self, script_dir: Path):
        """Initialize fzf interface with preview script paths."""
        self.info_script = script_dir / 'preview-info.sh'
        self.deps_script = script_dir / 'preview-deps.sh'

        if not self.info_script.exists() or not self.deps_script.exists():
            raise FileNotFoundError(
                f"Preview scripts not found in {script_dir}\n"
                "Make sure preview-info.sh and preview-deps.sh are in the same directory"
            )

    def run(self,
            input_data: str,
            prompt: str = 'Search > ',
            header: str = '',
            query: str = '',
            multi: bool = True,
            extra_bindings: Optional[List[str]] = None,
            extra_options: Optional[List[str]] = None,
            border_label: str = '',
            preview_label: str = '[ Info ]',
            search_description: bool = False) -> Optional[str]:
        """
        Run fzf with common configuration.

        Args:
            input_data: Data to pass to fzf stdin
            prompt: Prompt text to display
            header: Header text with keybinding help
            query: Initial query string
            multi: Enable multi-selection
            extra_bindings: Additional key bindings
            extra_options: Additional fzf options
            border_label: Label for the left panel border
            preview_label: Label for the preview panel

        Returns:
            Selected lines as string, or None if cancelled
        """
        cmd = [
            'fzf',
            '--ansi',
            '--border=rounded',
            '--height=95%',
            f'--preview={self.info_script} {{}}',
            '--preview-window=right:40%:wrap:border-left',
            f'--bind=ctrl-g:change-preview({self.deps_script} {{}})',
            f'--bind=ctrl-i:change-preview({self.info_script} {{}})',
            f'--prompt=  {prompt}',
            f'--preview-label={preview_label}',
            '--pointer=>',
            '--marker=*',
            '--info=default',
            '--padding=1',
            '--delimiter=\t',
            '--with-nth=1,2',  # Display both fields: marker+package, description
            f'--nth={1 if not search_description else "1,2"}',  # Search package only, or package+description
            f'--tiebreak={("begin,index" if search_description else "index")}',  # Prioritize earlier matches when searching descriptions
        ]

        if border_label:
            cmd.append(f'--border-label={border_label}')
            cmd.append('--border-label-pos=top')

        if header:
            cmd.append(f'--header={header}')
            cmd.append('--header-first')

        if multi:
            cmd.append('--multi')

        if query:
            cmd.append(f'--query={query}')

        if extra_bindings:
            for binding in extra_bindings:
                cmd.append(f'--bind={binding}')

        if extra_options:
            cmd.extend(extra_options)

        try:
            fzf = subprocess.Popen(
                cmd,
                stdin=subprocess.PIPE,
                stdout=subprocess.PIPE,
                text=True
            )

            stdout, _ = fzf.communicate(input_data)

            if fzf.returncode == 0 and stdout:
                return stdout.strip()
            return None
        except KeyboardInterrupt:
            print(Colors.yellow("\nSelection cancelled"))
            return None
        except (subprocess.SubprocessError, OSError) as e:
            print(Colors.red(f"Error running fzf: {e}"), file=sys.stderr)
            return None


